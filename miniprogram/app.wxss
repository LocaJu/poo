/**
 * SubletHub / 转租帮 — 全局设计系统
 * 色彩：青绿主色（信任、居住感）+ 玫瑰强调租金 + 暖橙辅助行动
 */

page {
  /* —— 主色阶（Teal，略降饱和更耐看）—— */
  --sh-primary: #0f766e;
  --sh-primary-mid: #0d9488;
  --sh-primary-light: #14b8a6;
  --sh-primary-soft: #5eead4;
  --sh-primary-tint: #ccfbf1;
  --sh-primary-faint: #f0fdfa;
  --sh-primary-dark: #115e59;

  /* —— 中性色（Zinc 系）—— */
  --sh-text: #18181b;
  --sh-text-secondary: #52525b;
  --sh-text-tertiary: #71717a;
  --sh-text-muted: #a1a1aa;
  --sh-border: #e4e4e7;
  --sh-border-light: #f4f4f5;
  --sh-surface: #ffffff;
  --sh-page-bg: #f4f6f8;
  --sh-page-bg-warm: #f6f7f4;

  /* —— 功能色—— */
  --sh-price: #e11d48;
  --sh-price-soft: #fff1f2;
  --sh-warn: #ea580c;
  --sh-warn-soft: #fff7ed;
  --sh-danger: #dc2626;
  --sh-success: #0f766e;

  /* —— 圆角 —— */
  --sh-radius-sm: 12rpx;
  --sh-radius-md: 20rpx;
  --sh-radius-lg: 28rpx;
  --sh-radius-xl: 36rpx;
  --sh-radius-pill: 999rpx;

  /* —— 阴影（带主色色相，更统一）—— */
  --sh-shadow-sm: 0 2rpx 12rpx rgba(15, 118, 110, 0.06);
  --sh-shadow-md: 0 8rpx 32rpx rgba(15, 118, 110, 0.1);
  --sh-shadow-card: 0 4rpx 24rpx rgba(24, 24, 27, 0.06);
  --sh-shadow-float: 0 12rpx 40rpx rgba(15, 118, 110, 0.18);

  /* —— 字阶 —— */
  --sh-font-title: 34rpx;
  --sh-font-body: 28rpx;
  --sh-font-small: 24rpx;
  --sh-font-caption: 22rpx;

  background-color: var(--sh-page-bg);
  font-size: var(--sh-font-body);
  color: var(--sh-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC',
    'Microsoft YaHei', sans-serif;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* 通用容器 */
.container {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 24rpx;
  background-color: var(--sh-page-bg);
}

/* 卡片皮肤（子页可复用类名） */
.sh-card {
  background: var(--sh-surface);
  border-radius: var(--sh-radius-md);
  box-shadow: var(--sh-shadow-card);
}

.sh-card--flat {
  box-shadow: none;
  border: 1rpx solid var(--sh-border-light);
}

/* 主按钮视觉参考 */
.sh-btn-primary {
  background: linear-gradient(135deg, var(--sh-primary) 0%, var(--sh-primary-mid) 100%);
  color: #fff;
  border-radius: var(--sh-radius-pill);
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
