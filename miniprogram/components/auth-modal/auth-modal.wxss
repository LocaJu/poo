.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
.modal {
  width: 560rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx;
}
.modal .title { font-size: 34rpx; font-weight: 500; display: block; }
.modal .desc { font-size: 28rpx; color: #666; display: block; margin-top: 16rpx; }
.btns { display: flex; justify-content: flex-end; gap: 24rpx; margin-top: 48rpx; }
.btn { padding: 20rpx 40rpx; border-radius: 8rpx; font-size: 28rpx; }
.btn.cancel { background: #f0f0f0; }
.btn.primary { background: #07c160; color: #fff; }
