.card {
  background: var(--sh-surface);
  border-radius: var(--sh-radius-lg);
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--sh-shadow-card);
  border: 1rpx solid var(--sh-border-light);
}

.card .title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--sh-text);
  display: block;
}

.card .version {
  font-size: 24rpx;
  color: var(--sh-text-muted);
  display: block;
  margin-top: 8rpx;
}

.card .desc {
  font-size: 28rpx;
  color: var(--sh-text-secondary);
  display: block;
  margin-top: 16rpx;
  line-height: 1.6;
}

.card .section {
  display: block;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--sh-border-light);
  font-size: 28rpx;
  color: var(--sh-text-secondary);
}

.card .section:last-child {
  border-bottom: none;
}
