.profile-page {
  min-height: 100vh;
  background: var(--sh-page-bg);
}

.profile-hero {
  position: relative;
  padding-bottom: 52rpx;
}

.hero-bg {
  height: 240rpx;
  background: linear-gradient(160deg, var(--sh-primary-dark) 0%, var(--sh-primary) 35%, var(--sh-primary-mid) 70%, var(--sh-primary-light) 100%);
  border-radius: 0 0 var(--sh-radius-xl) var(--sh-radius-xl);
  position: relative;
  overflow: hidden;
}

.hero-bg::after {
  content: '';
  position: absolute;
  width: 200%;
  height: 80rpx;
  left: -50%;
  bottom: -40rpx;
  background: var(--sh-page-bg);
  border-radius: 50%;
}

.user-card {
  margin: -108rpx 28rpx 0;
  background: var(--sh-surface);
  border-radius: var(--sh-radius-lg);
  padding: 36rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-shadow: var(--sh-shadow-md);
  border: 1rpx solid var(--sh-border-light);
  position: relative;
  z-index: 2;
}

.user-card.guest {
  align-items: center;
}

.avatar {
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  border: 4rpx solid var(--sh-primary-tint);
  flex-shrink: 0;
  background: var(--sh-border-light);
  box-shadow: var(--sh-shadow-sm);
}

.avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: var(--sh-text-muted);
  border-color: var(--sh-border);
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--sh-text);
  display: block;
  margin-bottom: 14rpx;
  letter-spacing: 0.5rpx;
}

.badges {
  display: flex;
  gap: 12rpx;
}

.badge {
  font-size: 22rpx;
  color: var(--sh-text-tertiary);
  background: var(--sh-page-bg);
  padding: 8rpx 18rpx;
  border-radius: var(--sh-radius-pill);
  border: 1rpx solid var(--sh-border-light);
}

.badge.verified {
  color: var(--sh-primary);
  background: var(--sh-primary-faint);
  border-color: var(--sh-primary-tint);
  font-weight: 600;
}

.login-btn {
  margin: 0 !important;
  width: 300rpx !important;
  background: linear-gradient(135deg, var(--sh-primary) 0%, var(--sh-primary-mid) 100%) !important;
  color: #fff !important;
  font-size: 28rpx !important;
  font-weight: 600 !important;
  border-radius: var(--sh-radius-pill) !important;
  border: none !important;
  box-shadow: var(--sh-shadow-md);
}

.grid-section {
  margin: 36rpx 28rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--sh-text-secondary);
  margin-bottom: 20rpx;
  display: block;
  letter-spacing: 1rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  background: var(--sh-surface);
  border-radius: var(--sh-radius-lg);
  padding: 32rpx 12rpx;
  box-shadow: var(--sh-shadow-card);
  border: 1rpx solid var(--sh-border-light);
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding: 8rpx 0;
  border-radius: var(--sh-radius-sm);
  transition: background 0.2s;
}

.grid-item:active {
  background: var(--sh-primary-faint);
}

.grid-icon {
  font-size: 48rpx;
  line-height: 1;
}

.grid-label {
  font-size: 22rpx;
  color: var(--sh-text-secondary);
  text-align: center;
  font-weight: 500;
}

.menu-list {
  margin: 28rpx;
  background: var(--sh-surface);
  border-radius: var(--sh-radius-lg);
  overflow: hidden;
  box-shadow: var(--sh-shadow-card);
  border: 1rpx solid var(--sh-border-light);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx 32rpx;
  border-bottom: 1rpx solid var(--sh-border-light);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger .menu-left {
  color: var(--sh-danger);
  font-weight: 500;
}

.menu-left {
  font-size: 30rpx;
  color: var(--sh-text);
  font-weight: 500;
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--sh-text-muted);
  font-weight: 300;
}
