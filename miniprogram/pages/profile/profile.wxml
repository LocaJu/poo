<view class="profile-page">
  <view class="profile-hero">
    <view class="hero-bg"></view>
    <view class="user-card" wx:if="{{isLogin && user}}">
      <image class="avatar" src="{{user.avatarUrl || '/images/avatar.png'}}" mode="aspectFill" />
      <view class="user-meta">
        <text class="nickname">{{user.nickName || '微信用户'}}</text>
        <view class="badges">
          <text class="badge verified" wx:if="{{user.isVerified}}">已认证</text>
          <text class="badge" wx:else>未认证</text>
        </view>
      </view>
    </view>
    <view class="user-card guest" wx:else>
      <view class="avatar placeholder">?</view>
      <view class="user-meta">
        <text class="nickname">登录后享受完整服务</text>
        <button class="login-btn" bindtap="handleLogin">微信一键登录</button>
      </view>
    </view>
  </view>

  <view class="grid-section">
    <text class="section-title">常用功能</text>
    <view class="grid">
      <view class="grid-item" data-url="/pages/map/map" bindtap="handleNav">
        <text class="grid-icon">🗺</text>
        <text class="grid-label">地图找房</text>
      </view>
      <view class="grid-item" data-url="/pages/chat/chat" bindtap="handleNav">
        <text class="grid-icon">💬</text>
        <text class="grid-label">消息</text>
      </view>
      <view class="grid-item" data-url="/pages/favorites/favorites" bindtap="handleNav">
        <text class="grid-icon">⭐</text>
        <text class="grid-label">我的收藏</text>
      </view>
      <view class="grid-item" data-url="/pages/my-houses/my-houses" bindtap="handleNav">
        <text class="grid-icon">📋</text>
        <text class="grid-label">我的房源</text>
      </view>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" data-url="/pages/publish/publish" bindtap="handleNav">
      <text class="menu-left">发布房源</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" data-url="/pages/search/search" bindtap="handleNav">
      <text class="menu-left">高级搜索</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" data-url="/pages/about/about" bindtap="handleNav">
      <text class="menu-left">关于与设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item danger" wx:if="{{isLogin}}" bindtap="handleLogout">
      <text class="menu-left">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
