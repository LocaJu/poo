<view class="container">
  <view class="search-row">
    <input class="search-input" placeholder="搜索标题、描述" value="{{keyword}}" confirm-type="search"
      bindconfirm="onKeywordConfirm" />
  </view>
  <view class="order-bar">
    <text class="order-item {{filters.orderBy === 'latest' ? 'active' : ''}}" data-order="latest" bindtap="handleOrderChange">最新</text>
    <text class="order-item {{filters.orderBy === 'price_asc' ? 'active' : ''}}" data-order="price_asc" bindtap="handleOrderChange">租金升序</text>
    <text class="order-item {{filters.orderBy === 'price_desc' ? 'active' : ''}}" data-order="price_desc" bindtap="handleOrderChange">租金降序</text>
  </view>
  <view class="list">
    <block wx:for="{{list}}" wx:key="id">
      <view class="house-item" data-id="{{item.id}}" bindtap="handleTapHouse">
        <image class="thumb" src="{{item.images ? item.images.split(',')[0] : ''}}" mode="aspectFill" />
        <view class="info">
          <text class="title">{{item.title}}</text>
          <text class="meta">{{item.type}} · {{item.area}}㎡</text>
          <text class="price">{{item.price}}元/月</text>
        </view>
      </view>
    </block>
  </view>
  <view class="empty" wx:if="{{list.length === 0 && !loading}}">暂无结果</view>
  <view class="nomore" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>
</view>
