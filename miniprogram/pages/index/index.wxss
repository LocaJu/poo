.search-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.search-placeholder {
  color: #999;
  font-size: 28rpx;
}
.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.house-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.house-item .thumb {
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
  background: #eee;
}
.house-item .info {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.house-item .title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.house-item .meta {
  font-size: 24rpx;
  color: #999;
}
.house-item .price {
  font-size: 32rpx;
  color: #07c160;
  font-weight: 600;
}
.empty, .loading, .nomore {
  text-align: center;
  padding: 48rpx;
  color: #999;
  font-size: 28rpx;
}
