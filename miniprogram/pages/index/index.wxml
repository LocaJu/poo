<view class="container">
  <view class="search-bar" bindtap="handleTapSearch">
    <text class="search-placeholder">搜索房源、区域</text>
  </view>
  <view class="list" wx:if="{{list.length > 0}}">
    <block wx:for="{{list}}" wx:key="id">
      <view class="house-item" data-id="{{item.id}}" bindtap="handleTapHouse">
        <image class="thumb" src="{{item.images ? item.images.split(',')[0] : '/images/placeholder.png'}}" mode="aspectFill" />
        <view class="info">
          <text class="title">{{item.title}}</text>
          <text class="meta">{{item.type}} · {{item.area}}㎡</text>
          <text class="price">{{item.price}}元/月</text>
        </view>
      </view>
    </block>
  </view>
  <view class="empty" wx:elif="{{!loading}}">
    <text>暂无房源</text>
  </view>
  <view class="loading" wx:if="{{loading && list.length > 0}}">加载中...</view>
  <view class="nomore" wx:if="{{!hasMore && list.length > 0}}">没有更多了</view>
</view>
