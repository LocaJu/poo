.item { display: flex; background: #fff; border-radius: 16rpx; margin-bottom: 24rpx; overflow: hidden; }
.item .thumb { width: 200rpx; height: 200rpx; flex-shrink: 0; background: #eee; }
.item .info { flex: 1; padding: 24rpx; }
.item .title { font-size: 30rpx; display: block; }
.item .status { font-size: 24rpx; color: #999; display: block; margin-top: 8rpx; }
.item .price { font-size: 32rpx; color: #07c160; display: block; margin-top: 8rpx; }
.empty, .nomore { text-align: center; padding: 48rpx; color: #999; }
