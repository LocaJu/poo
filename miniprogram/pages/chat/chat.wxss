.empty {
  text-align: center;
  padding: 100rpx 40rpx 80rpx;
  color: var(--sh-text-secondary);
  font-size: 30rpx;
}

.empty .hint {
  display: block;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: var(--sh-text-muted);
  line-height: 1.55;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list .item {
  background: var(--sh-surface);
  border-radius: var(--sh-radius-lg);
  padding: 32rpx 28rpx;
  font-size: 28rpx;
  color: var(--sh-text);
  font-weight: 500;
  box-shadow: var(--sh-shadow-card);
  border: 1rpx solid var(--sh-border-light);
}

.list .item:active {
  opacity: 0.92;
}
