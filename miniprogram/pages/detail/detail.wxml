<view class="container" wx:if="{{house}}">
  <swiper class="swiper" indicator-dots autoplay>
    <block wx:for="{{house.imageList}}" wx:key="*this">
      <swiper-item>
        <image src="{{item}}" mode="aspectFill" class="slide-img" />
      </swiper-item>
    </block>
    <swiper-item wx:if="{{house.imageList.length === 0}}">
      <view class="no-img">暂无图片</view>
    </swiper-item>
  </swiper>
  <view class="card">
    <text class="price">{{house.price}}元/月</text>
    <text class="title">{{house.title}}</text>
    <text class="meta">{{house.type}} · {{house.area}}㎡ · {{house.deposit}}</text>
    <text class="desc">{{house.description}}</text>
    <view class="location" wx:if="{{house.location && house.location.address}}">
      <text>位置：{{house.location.address}}</text>
    </view>
  </view>
  <view class="actions">
    <view class="btn icon-btn" bindtap="handleTapFavorite">
      <text class="{{favorited ? 'active' : ''}}">{{favorited ? '已收藏' : '收藏'}}</text>
    </view>
    <button class="btn primary" bindtap="handleTapChat">联系TA</button>
    <view class="btn text" bindtap="handleTapComplaint">举报</view>
  </view>
</view>
