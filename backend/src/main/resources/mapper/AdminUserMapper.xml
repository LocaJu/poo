<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sublethub.mapper.AdminUserMapper">

  <resultMap id="BaseResultMap" type="com.sublethub.entity.AdminUser">
    <id column="id" property="id"/>
    <result column="username" property="username"/>
    <result column="password" property="password"/>
    <result column="name" property="name"/>
    <result column="create_time" property="createTime"/>
    <result column="update_time" property="updateTime"/>
  </resultMap>

  <select id="selectById" resultMap="BaseResultMap">
    SELECT * FROM admin_users WHERE id = #{id}
  </select>

  <select id="selectByUsername" resultMap="BaseResultMap">
    SELECT * FROM admin_users WHERE username = #{username}
  </select>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO admin_users (username, password, name, create_time, update_time)
    VALUES (#{username}, #{password}, #{name}, NOW(), NOW())
  </insert>

  <update id="updateById">
    UPDATE admin_users SET username = #{username}, password = #{password}, name = #{name}, update_time = NOW()
    WHERE id = #{id}
  </update>
</mapper>
